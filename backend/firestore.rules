rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── helpers ──────────────────────────────────────────────────────
    function isSignedIn()        { return request.auth != null; }
    function isOwner(uid)        { return request.auth.uid == uid; }
    function isAdmin()           {
      return isSignedIn() &&
        get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'admin';
    }

    // ── profiles ─────────────────────────────────────────────────────
    match /profiles/{userId} {
      allow read:   if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── hostel applications ──────────────────────────────────────────
    match /hostelApplications/{docId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin() || isOwner(resource.data.userId);
      allow delete: if isAdmin();
    }

    // ── fee challans & payments ──────────────────────────────────────
    match /feeChallans/{docId} {
      allow read:   if isSignedIn();
      allow write:  if isAdmin();
    }
    match /feePayments/{docId} {
      allow read:   if isSignedIn();
      allow write:  if isAdmin();
    }
    match /studentBalance/{userId} {
      allow read:   if isOwner(userId) || isAdmin();
      allow write:  if isAdmin();
    }

    // ── rooms / beds ─────────────────────────────────────────────────
    match /hostels/{hostelId} {
      allow read:   if isSignedIn();
      allow write:  if isAdmin();
    }
    match /rooms/{roomId} {
      allow read:   if isSignedIn();
      allow write:  if isAdmin();
    }
    match /beds/{bedId} {
      allow read:   if isSignedIn();
      allow write:  if isAdmin();
    }

    // ── notifications ────────────────────────────────────────────────
    match /notifications/{docId} {
      allow read:   if isOwner(resource.data.userId);
      allow create: if isAdmin();
      allow update: if isOwner(resource.data.userId); // mark read
      allow delete: if isAdmin();
    }

    // ── complaints ───────────────────────────────────────────────────
    match /complaints/{docId} {
      allow read:   if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin() || isOwner(resource.data.userId);
      allow delete: if isAdmin();
    }

    // ── mess & gym ───────────────────────────────────────────────────
    match /messRegistrations/{docId} {
      allow read:   if isSignedIn();
      allow write:  if isSignedIn();
    }
    match /gymRegistrations/{docId} {
      allow read:   if isSignedIn();
      allow write:  if isSignedIn();
    }

    // ── settings ─────────────────────────────────────────────────────
    match /settings/{docId} {
      allow read:   if isSignedIn();
      allow write:  if isAdmin();
    }

    // ── notice board ─────────────────────────────────────────────────
    match /notices/{docId} {
      allow read:   if isSignedIn();
      allow write:  if isAdmin();
    }
  }
}
