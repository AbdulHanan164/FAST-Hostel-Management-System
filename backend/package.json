{
  "name": "fast-hostel-backend",
  "version": "1.0.0",
  "description": "Firebase Cloud Functions for FAST Hostel Management System",
  "main": "functions/index.js",
  "scripts": {
    "deploy": "firebase deploy --only functions",
    "deploy:debug": "firebase deploy --only functions --debug",
    "logs": "firebase functions:log",
    "shell": "firebase functions:shell",
    "emulate": "firebase emulators:start --only functions,firestore"
  },
  "engines": {
    "node": "18"
  },
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^4.7.0"
  },
  "devDependencies": {
    "firebase-tools": "^13.0.0"
  },
  "private": true
}
