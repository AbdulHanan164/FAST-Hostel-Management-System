# ============================================================
# FAST Hostel Management System — .gitignore
# ============================================================

# ── Claude AI (never push) ───────────────────────────────────
.claude/
.claude

# ── Flutter / Dart ───────────────────────────────────────────
# Build outputs
build/
frontend/build/

# Dart tool cache
.dart_tool/
frontend/.dart_tool/

# Flutter generated files
.flutter-plugins
.flutter-plugins-dependencies
frontend/.flutter-plugins
frontend/.flutter-plugins-dependencies

# pubspec lock (optional: keep for reproducibility, but often excluded)
# pubspec.lock

# Dart/Flutter generated code
*.g.dart
*.freezed.dart
*.mocks.dart

# Coverage
coverage/
frontend/coverage/

# ── Firebase / Google ────────────────────────────────────────
# Firebase config with API keys — NEVER commit these
google-services.json
GoogleService-Info.plist
frontend/google-services.json
frontend/GoogleService-Info.plist
frontend/android/app/google-services.json
frontend/ios/Runner/GoogleService-Info.plist

# Firebase options (contains project credentials)
# firebase_options.dart  ← kept in repo for build; remove if it has secrets

# Firebase debug token (App Check)
.firebase_app_check_debug_token.txt

# Firebase CLI
.firebaserc
firebase-debug.log
firebase-debug.*.log

# ── Environment / Secrets ────────────────────────────────────
.env
.env.*
*.env
*.env.*
secrets.json
secrets.yaml
config/secrets*

# Flutter env files
frontend/.env
frontend/.env.*
frontend/assets/.env
frontend/lib/config/env_config.local.dart

# ── Node.js (backend / tooling) ──────────────────────────────
node_modules/
frontend/node_modules/
backend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock

# ── Python (backend) ─────────────────────────────────────────
__pycache__/
backend/__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
backend/.Python
venv/
backend/venv/
.venv/
backend/.venv/
env/
backend/env/
ENV/
*.egg-info/
dist/
eggs/
*.egg
.pytest_cache/
.coverage
htmlcov/
*.log

# ── IDE / Editor ─────────────────────────────────────────────
# IntelliJ / Android Studio
.idea/
*.iml
*.iws
*.ipr
.idea/workspace.xml
.idea/tasks.xml
.idea/gradle.xml
.idea/assetWizardSettings.xml
.idea/dictionaries
.idea/libraries
.idea/caches

# VS Code
.vscode/
*.code-workspace

# Xcode
*.xcworkspace/
xcuserdata/
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.moved-aside
DerivedData/
*.hmap
*.ipa

# ── OS Files ─────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Android ──────────────────────────────────────────────────
frontend/android/.gradle/
frontend/android/captures/
frontend/android/gradlew
frontend/android/gradlew.bat
frontend/android/local.properties
frontend/android/key.properties
*.keystore
*.jks

# ── iOS ──────────────────────────────────────────────────────
frontend/ios/Pods/
frontend/ios/.symlinks/
frontend/ios/Flutter/Flutter.framework
frontend/ios/Flutter/Flutter.podspec
frontend/ios/Flutter/App.framework
frontend/ios/Flutter/ephemeral/

# ── Misc ─────────────────────────────────────────────────────
*.bak
*.tmp
*.swp
*~
.history/
